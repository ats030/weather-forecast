############################################################
# Pythonプロジェクト用 .gitignore（統合・日本語完全版）
# ベース: Toptal Python + 実務最適化 + Claude Code対応
############################################################


############################################################
# 1. Python実行・キャッシュ関連（再生成可能ファイル）
############################################################

# バイトコード・キャッシュ
__pycache__/
*.py[cod]
*$py.class

# C拡張
*.so

# Cythonデバッグ
cython_debug/


############################################################
# 2. ビルド・配布関連（再生成可能）
############################################################

.Python
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# パッケージメタ情報
*.egg-info/
.installed.cfg
*.egg
MANIFEST


############################################################
# 3. PyInstaller（ビルド中間生成物）
############################################################

*.manifest
*.spec


############################################################
# 4. ログ・一時ファイル（Claude Code含む）
############################################################

# 一般ログ
*.log

# pipログ
pip-log.txt
pip-delete-this-directory.txt

# 一時ファイル・キャッシュ
tmp/
temp/
.cache/


############################################################
# 5. テスト・カバレッジ
############################################################

htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/


############################################################
# 6. フレームワーク別
############################################################

# Django
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask
instance/
.webassets-cache

# Scrapy
.scrapy


############################################################
# 7. ドキュメント・ビルド
############################################################

docs/_build/
/site


############################################################
# 8. Notebook / 対話環境
############################################################

.ipynb_checkpoints
profile_default/
ipython_config.py


############################################################
# 9. 仮想環境・環境変数（最重要：機密防止）
############################################################

# 仮想環境
.env
.env.*
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# 環境変数ファイル（APIキー等）
# → GitHub公開時の重大事故防止
.env.local


############################################################
# 10. 依存管理ツール
############################################################

# pipenv（通常はlockは含めるが状況により除外）
# Pipfile.lock

# poetry（通常は含めるがライブラリ用途では除外あり）
# poetry.lock

# Poetryローカル設定（環境依存）
poetry.toml

# pdm
.pdm.toml
# pdm.lock

# PEP582
__pypackages__/


############################################################
# 11. 型チェック・Lint・解析ツール
############################################################

.mypy_cache/
.dmypy.json
dmypy.json

.pyre/
.pytype/

.ruff_cache/


############################################################
# 12. IDE / エディタ設定（ローカル依存）
############################################################

.vscode/
.idea/

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject


############################################################
# 13. OS依存ファイル
############################################################

.DS_Store
Thumbs.db


############################################################
# 14. Claude Code / AI生成物対策（重要）
############################################################

# AI生成ログ・一時成果物
*.generated.*
*.tmp
*.bak

# 大量生成物対策（必要に応じて調整）
output/
artifacts/


############################################################
# 15. その他
############################################################

# 翻訳
*.mo
*.pot

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# PyBuilder
.pybuilder/
target/


############################################################
# 注意事項
############################################################

# 1. 「再生成可能なもの」は基本的にコミットしない
# 2. 「機密情報（.env）」は絶対に含めない
# 3. lockファイルは用途により判断（アプリは含める、ライブラリは除外も検討）
# 4. Claude Code生成物は必ず確認し、不要ならignoreへ追加
# 5. 初回コミット前に必ず `git status` で検証すること
############################################################